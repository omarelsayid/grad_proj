# ── Embedding ────────────────────────────────────────────────────────────────
# "local" uses sentence-transformers on your CPU (no API key needed)
# "hf_inference" calls the HF Inference API (requires HF_TOKEN)
EMBEDDING_PROVIDER=local
HF_TOKEN=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── LLM (OpenAI-compatible) ──────────────────────────────────────────────────
# Leave LLM_BASE_URL empty to use fallback mode (returns retrieved context)
# OpenAI:   LLM_BASE_URL=https://api.openai.com/v1  LLM_API_KEY=sk-...
# Groq:     LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.1-8b-instant
# Ollama:   LLM_BASE_URL=http://localhost:11434/v1  LLM_API_KEY=ollama
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ── Vector store ─────────────────────────────────────────────────────────────
CHROMA_DIR=./app/data/store

# ── PDF ──────────────────────────────────────────────────────────────────────
# Path to the company policy PDF (relative to backend/ or absolute)
PDF_PATH=../../SkillSync_Company_Policy_2026.pdf

# ── Retrieval ────────────────────────────────────────────────────────────────
TOP_K=5

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
