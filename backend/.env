# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL (Supabase or local) ────────────────────────────────────────────
# Use Supabase connection string (found in Project Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skillsync_db

# Or for local PostgreSQL:
# DATABASE_URL=postgresql://skillsync:skillsync_password@localhost:5432/skillsync_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=skillsync_jwt_secret_key_minimum_32_characters_abc123xyz
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=skillsync_refresh_secret_different_key_32chars_xyz789
REFRESH_TOKEN_EXPIRES_IN=30d

# ── ML Service ────────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ── Redis (BullMQ — optional, workers won't start if unavailable) ─────────────
REDIS_URL=redis://localhost:6379

# ── CORS (Flutter Web dev server) ────────────────────────────────────────────
CORS_ORIGIN=*

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5000
